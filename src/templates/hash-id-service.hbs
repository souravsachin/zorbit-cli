import { Injectable } from '@nestjs/common';
import * as crypto from 'crypto';

/**
 * Service for generating Zorbit short hash identifiers.
 *
 * Pattern: <PREFIX>-<4-char hex>
 * Examples: O-92AF, U-81F3, R-51AA
 *
 * Rules:
 * - Immutable once assigned
 * - Globally unique
 * - Non-sequential
 */
@Injectable()
export class HashIdService {
  /**
   * Generate a short hash identifier with the given prefix.
   */
  generate(prefix: string): string {
    const hash = crypto.randomBytes(2).toString('hex').toUpperCase();
    return `${prefix}-${hash}`;
  }

  /**
   * Validate that a hash ID matches the expected format.
   */
  validate(hashId: string, prefix?: string): boolean {
    const pattern = prefix
      ? new RegExp(`^${prefix}-[0-9A-F]{4}$`)
      : /^[A-Z]+-[0-9A-F]{4}$/;
    return pattern.test(hashId);
  }
}
