      zorbit-app-hi_sme_quotation \
      zorbit-app-hi_uw_decisioning \
      zorbit-app-jayna \
      zorbit-app-manufacturing_demo \
      zorbit-app-mi_quotation \
      zorbit-app-network_empanelment_application \
      zorbit-app-network_empanelment_workflow \
      zorbit-app-pcg4 \
      zorbit-app-pcg5 \
      zorbit-app-product_pricing \
      zorbit-app-prospect_portal \
      zorbit-app-retail_banking_demo \
      zorbit-app-sample \
      zorbit-app-sample_module \
      zorbit-app-slice_of_pie \
      zorbit-app-uw_workflow \
      zorbit-app-wealth_mgmt_demo \
      zorbit-app-zmb_selftest \
      zorbit-portal-customer \
      zorbit-portal-prospect ; do \
      if [ -f "/app/${svc}/package.json" ]; then \
        echo "→ installing deps for ${svc}"; \
        (cd "/app/${svc}" && npm ci --omit=dev --no-audit --no-fund); \
      fi; \
    done

# M5 / Strategy C (2026-04-26): prune SDK peer-dep duplicates so Node
# resolves @nestjs/* + typeorm + rxjs from the consumer's own node_modules,
# not the SDK's. See 00_docs/platform/sdk-peer-dep-strategy.md +
# Dockerfile.core.j2 for full rationale.
RUN set -eux; \
    for svc in /app/zorbit-*; do \
      sdk_nm="${svc}/node_modules/@zorbit-platform/sdk-node/node_modules"; \
      if [ -d "${sdk_nm}" ]; then \
        echo "→ pruning SDK nested peer-deps for ${svc##*/}"; \
        rm -rf "${sdk_nm}/@nestjs"          \
               "${sdk_nm}/typeorm"           \
               "${sdk_nm}/reflect-metadata"  \
               "${sdk_nm}/rxjs"              \
               "${sdk_nm}/passport"          \
               "${sdk_nm}/passport-jwt"; \
      fi; \
    done

COPY 02_repos/zorbit-cli/scripts/templates/ecosystems/apps.ecosystem.config.js \
     /app/ecosystem.config.js

WORKDIR /app
EXPOSE 3200-3599

HEALTHCHECK --interval=30s --timeout=5s --start-period=120s --retries=3 \
  CMD curl -fsSk http://localhost:3200/api/v1/G/health || exit 1

CMD ["pm2-runtime", "ecosystem.config.js"]
