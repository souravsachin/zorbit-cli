# ---------------------------------------------------------------------------
# docker-compose template for ONE Zorbit environment.
# ---------------------------------------------------------------------------
# Rendered to: /etc/zorbit/<env>/docker-compose.yml
#
# Jinja-style placeholders (rendered by package-bundle.sh / bootstrap-env.sh):
#   {{ENV_PREFIX}}      — ze | zq | zd | zu | zp
#   {{ENV_NAME}}        — dev | qa | demo | uat | prod
#   {{VERSION}}         — v0.1.0 (git tag)
#   {{WEB_HOST_PORT}}   — 80 or 443 (env-specific)
#
# Networks:
#   {{ENV_PREFIX}}-net       — env-local (this compose creates it)
#   zs-shared-net            — shared across non-prod envs (external, pre-existing)
#
# Bundle containers reference images built by package-bundle.sh:
#   zorbit-<bundle>:<version>  (loaded via `docker load -i images.tar`)
# ---------------------------------------------------------------------------

version: "3.8"

networks:
  {{ENV_PREFIX}}-net:
    driver: bridge
  zs-shared-net:
    external: true

services:

  # -------------------------------------------------------------------------
  # CORE bundle
  # -------------------------------------------------------------------------
  {{ENV_PREFIX}}-core:
    image: zorbit-core:{{VERSION}}
    container_name: {{ENV_PREFIX}}-core
    restart: unless-stopped
    env_file:
      - ./env/core.env
    environment:
      NODE_ENV: {{ENV_NAME}}
      ZORBIT_ENV_PREFIX: {{ENV_PREFIX}}
    networks:
      - {{ENV_PREFIX}}-net
      - zs-shared-net
    ports:
      - "3000-3099:3000-3099"
    healthcheck:
      test: ["CMD", "curl", "-fsSk", "http://localhost:3001/api/v1/G/health"]
      interval: 30s
      timeout: 5s
      retries: 5

  # -------------------------------------------------------------------------
  # PFS bundle
  # -------------------------------------------------------------------------
  {{ENV_PREFIX}}-pfs:
    image: zorbit-pfs:{{VERSION}}
    container_name: {{ENV_PREFIX}}-pfs
    restart: unless-stopped
    env_file:
      - ./env/pfs.env
    environment:
      NODE_ENV: {{ENV_NAME}}
      ZORBIT_ENV_PREFIX: {{ENV_PREFIX}}
    networks:
      - {{ENV_PREFIX}}-net
      - zs-shared-net
    ports:
      - "3100-3199:3100-3199"
    depends_on:
      {{ENV_PREFIX}}-core:
        condition: service_healthy

  # -------------------------------------------------------------------------
  # APPS bundle
  # -------------------------------------------------------------------------
  {{ENV_PREFIX}}-apps:
    image: zorbit-apps:{{VERSION}}
    container_name: {{ENV_PREFIX}}-apps
    restart: unless-stopped
    env_file:
      - ./env/apps.env
    environment:
      NODE_ENV: {{ENV_NAME}}
      ZORBIT_ENV_PREFIX: {{ENV_PREFIX}}
    networks:
      - {{ENV_PREFIX}}-net
      - zs-shared-net
    ports:
      - "3200-3599:3200-3599"
    depends_on:
      {{ENV_PREFIX}}-core:
        condition: service_healthy

  # -------------------------------------------------------------------------
  # AI bundle
  # -------------------------------------------------------------------------
  {{ENV_PREFIX}}-ai:
    image: zorbit-ai:{{VERSION}}
    container_name: {{ENV_PREFIX}}-ai
    restart: unless-stopped
    env_file:
      - ./env/ai.env
    environment:
      NODE_ENV: {{ENV_NAME}}
      ZORBIT_ENV_PREFIX: {{ENV_PREFIX}}
    networks:
      - {{ENV_PREFIX}}-net
      - zs-shared-net
    ports:
      - "3600-3799:3600-3799"
    depends_on:
      {{ENV_PREFIX}}-core:
        condition: service_healthy

  # -------------------------------------------------------------------------
  # WEB bundle (static SPA via nginx)
  # -------------------------------------------------------------------------
  {{ENV_PREFIX}}-web:
    image: zorbit-web:{{VERSION}}
    container_name: {{ENV_PREFIX}}-web
    restart: unless-stopped
    networks:
      - {{ENV_PREFIX}}-net
      - zs-shared-net
    ports:
      - "{{WEB_HOST_PORT}}:80"
    depends_on:
      - {{ENV_PREFIX}}-core
      - {{ENV_PREFIX}}-pfs
      - {{ENV_PREFIX}}-apps
