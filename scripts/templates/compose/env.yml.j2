# ---------------------------------------------------------------------------
# docker-compose template for ONE Zorbit environment.
# ---------------------------------------------------------------------------
# Rendered to: /etc/zorbit/<env>/docker-compose.yml
#
# Jinja-style placeholders (rendered by package-bundle.sh / bootstrap-env.sh):
#   {{ENV_PREFIX}}      — ze | zq | zd | zu | zp
#   {{ENV_NAME}}        — dev | qa | demo | uat | prod
#   {{VERSION}}         — v0.1.0 (git tag)
#   {{WEB_HOST_PORT}}   — 80 or 443 (env-specific)
#
# Networks:
#   {{ENV_PREFIX}}-net       — env-local (this compose creates it)
#   zs-shared-net            — shared across non-prod envs (external, pre-existing)
#
# Bundle containers reference images pushed by build-and-push-bundles.sh:
#   {{IMAGE_REGISTRY_BASE}}/zorbit-<bundle>:<version>
# Default {{IMAGE_REGISTRY_BASE}} = ghcr.io/souravsachin (per all-repos.yaml).
# For air-gapped installs, set {{IMAGE_REGISTRY_BASE}} to "" and load images
# from `package-bundle.sh` tarballs via `docker load -i images.tar`.
# ---------------------------------------------------------------------------
# CPU PROTECTION (2026-04-25, fix/F2-cpu-protection):
#   ze-core / ze-pfs / ze-apps / ze-ai  -> 2.0 vCPU / 2G mem
#   ze-web                              -> 0.5 vCPU / 512M mem
#   Each block ships both Swarm-style `deploy.resources` and non-swarm
#   `cpus`/`mem_limit` so `docker compose up` (Compose v2, non-swarm) enforces
#   the cap. Without this, a single PM2 restart-loop saturated all 4 vCPU
#   (cycle-102 incident: load avg 21).
# ---------------------------------------------------------------------------

version: "3.8"

networks:
  {{ENV_PREFIX}}-net:
    driver: bridge
  zs-shared-net:
    external: true

services:

  # -------------------------------------------------------------------------
  # CORE bundle
  # -------------------------------------------------------------------------
  {{ENV_PREFIX}}-core:
    image: {{IMAGE_REGISTRY_BASE}}/zorbit-core:{{VERSION}}
    container_name: {{ENV_PREFIX}}-core
    restart: unless-stopped
    env_file:
      - ./env/core.env
    environment:
      NODE_ENV: {{ENV_NAME}}
      ZORBIT_ENV_PREFIX: {{ENV_PREFIX}}
    networks:
      - {{ENV_PREFIX}}-net
      - zs-shared-net
    ports:
      - "3000-3099:3000-3099"
    healthcheck:
      test: ["CMD", "curl", "-fsSk", "http://localhost:3001/api/v1/G/health"]
      interval: 30s
      timeout: 5s
      retries: 5
    # CPU PROTECTION
    cpus: 2.0
    mem_limit: 2g
    mem_reservation: 256m
    deploy:
      resources:
        limits:
          cpus: '2.0'
          memory: 2G
        reservations:
          cpus: '0.5'
          memory: 256M

  # -------------------------------------------------------------------------
  # PFS bundle
  # -------------------------------------------------------------------------
  {{ENV_PREFIX}}-pfs:
    image: {{IMAGE_REGISTRY_BASE}}/zorbit-pfs:{{VERSION}}
    container_name: {{ENV_PREFIX}}-pfs
    restart: unless-stopped
    env_file:
      - ./env/pfs.env
    environment:
      NODE_ENV: {{ENV_NAME}}
      ZORBIT_ENV_PREFIX: {{ENV_PREFIX}}
    networks:
      - {{ENV_PREFIX}}-net
      - zs-shared-net
    ports:
      - "3100-3199:3100-3199"
    depends_on:
      {{ENV_PREFIX}}-core:
        condition: service_healthy
    # CPU PROTECTION
    cpus: 2.0
    mem_limit: 2g
    mem_reservation: 256m
    deploy:
      resources:
        limits:
          cpus: '2.0'
          memory: 2G
        reservations:
          cpus: '0.5'
          memory: 256M

  # -------------------------------------------------------------------------
  # APPS bundle
  # -------------------------------------------------------------------------
  {{ENV_PREFIX}}-apps:
    image: {{IMAGE_REGISTRY_BASE}}/zorbit-apps:{{VERSION}}
    container_name: {{ENV_PREFIX}}-apps
    restart: unless-stopped
    env_file:
      - ./env/apps.env
    environment:
      NODE_ENV: {{ENV_NAME}}
      ZORBIT_ENV_PREFIX: {{ENV_PREFIX}}
    networks:
      - {{ENV_PREFIX}}-net
      - zs-shared-net
    ports:
      - "3200-3599:3200-3599"
    depends_on:
      {{ENV_PREFIX}}-core:
        condition: service_healthy
    # CPU PROTECTION
    cpus: 2.0
    mem_limit: 2g
    mem_reservation: 256m
    deploy:
      resources:
        limits:
          cpus: '2.0'
          memory: 2G
        reservations:
          cpus: '0.5'
          memory: 256M

  # -------------------------------------------------------------------------
  # AI bundle
  # -------------------------------------------------------------------------
  {{ENV_PREFIX}}-ai:
    image: {{IMAGE_REGISTRY_BASE}}/zorbit-ai:{{VERSION}}
    container_name: {{ENV_PREFIX}}-ai
    restart: unless-stopped
    env_file:
      - ./env/ai.env
    environment:
      NODE_ENV: {{ENV_NAME}}
      ZORBIT_ENV_PREFIX: {{ENV_PREFIX}}
    networks:
      - {{ENV_PREFIX}}-net
      - zs-shared-net
    ports:
      - "3600-3799:3600-3799"
    depends_on:
      {{ENV_PREFIX}}-core:
        condition: service_healthy
    # CPU PROTECTION
    cpus: 2.0
    mem_limit: 2g
    mem_reservation: 256m
    deploy:
      resources:
        limits:
          cpus: '2.0'
          memory: 2G
        reservations:
          cpus: '0.5'
          memory: 256M

  # -------------------------------------------------------------------------
  # WEB bundle (static SPA via nginx)
  # -------------------------------------------------------------------------
  {{ENV_PREFIX}}-web:
    image: {{IMAGE_REGISTRY_BASE}}/zorbit-web:{{VERSION}}
    container_name: {{ENV_PREFIX}}-web
    restart: unless-stopped
    networks:
      - {{ENV_PREFIX}}-net
      - zs-shared-net
    ports:
      - "{{WEB_HOST_PORT}}:80"
    depends_on:
      - {{ENV_PREFIX}}-core
      - {{ENV_PREFIX}}-pfs
      - {{ENV_PREFIX}}-apps
    # CPU PROTECTION
    cpus: 0.5
    mem_limit: 512m
    mem_reservation: 64m
    deploy:
      resources:
        limits:
          cpus: '0.5'
          memory: 512M
        reservations:
          cpus: '0.1'
          memory: 64M
